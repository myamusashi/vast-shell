{
	"appearance": {
		"animations": {
			"durations": {
				"scale": 1
			}
		},
		"fonts": {
			"family": {
				"material": "Material Symbols Rounded",
				"mono": "Maple Mono NF",
				"sans": "Google Sans Flex"
			},
			"size": {
				"scale": 1
			}
		}
	},
	"bar": {
		"alwaysOpenBar": true,
		"barHeight": 48,
		"compact": false,
		"visibleWorkspace": 5,
		"workspacesIndicator": "dot"
	},
	"colors": {
		"isDarkMode": true,
		"matugenConfigPathForDarkColor": "/home/<user>/.config/shell/dark-colors.json",
		"matugenConfigPathForLightColor": "/home/<user>/.config/shell/light-colors.json",
		"staticColorsPath": "/home/<user>/.config/shell/colors.json",
		"useMatugenColor": true,
		"useStaticColors": false
	},
	"generals": {
		"alpha": 0.5,
		"apps": {
			"audio": "pavucontrol-qt",
			"fileExplorer": "pcmanfm-qt",
			"imageViewer": "lximage-qt",
			"playback": "mpv",
			"terminal": "foot",
			"videoViewer": "mpv"
		},
		"battery": {
			"warnLevels": [
				{
					"icon": "battery-020",
					"level": 20,
					"urgency": "normal",
					"message": "Dude, plug your charger",
					"title": "Low battery"
				},
				{
					"icon": "battery-010",
					"level": 10,
					"urgency": "low",
					"message": "Dude, your battery dying",
					"title": "Battery dying"
				},
				{
					"icon": "battery-000",
					"level": 5,
					"urgency": "critical",
					"message": "PUT IT IN NOW",
					"title": "Critical level"
				}
			]
		},
		"enableOuterBorder": false,
		"followFocusMonitor": true,
		"outerBorderSize": 5,
		"transparent": false
	},
	"language": "",
	"wallpaper": {
		"enabledWallpaper": true,
		"transition": "random",
		"transitionDuration": 600,
		"transitionLowPerfMode": false,
		"visibleWallpaper": 3,
		"wallpaperDir": "/home/<user>/Pictures/wallpapers"
	},
	"weather": {
		"enableQuickSummary": true,
		"latitude": "",
		"longitude": "",
		"reloadTime": 1800000
	}
}
